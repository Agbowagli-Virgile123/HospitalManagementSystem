@using HospitalManagementSystem.Models


<style>
    /* ==========================================
       Backdrop
    ========================================== */

    .app-modal-backdrop {
        position: fixed;
        inset: 0;
        z-index: 1055;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 1rem;
        background: rgba(15, 23, 42, .45);
        backdrop-filter: blur(6px);
        animation: modalFade .25s ease;
    }

    /* ==========================================
       Modal
    ========================================== */

    .app-modal {
        background: #fff;
        border-radius: 18px;
        box-shadow: 0 20px 60px rgba(0,0,0,.25);
        display: flex;
        flex-direction: column;
        overflow: hidden;
        animation: modalSlide .25s ease;
        max-height: calc(100vh - 40px);
    }

    /* ==========================================
       Sizes
    ========================================== */

    .modal-sm {
        width: 420px;
    }

    .modal-md {
        width: 650px;
    }

    .modal-lg {
        width: 900px;
    }

    .modal-xl {
        width: 1140px;
    }

    .modal-full {
        width: calc(100vw - 30px);
        height: calc(100vh - 30px);
        border-radius: 12px;
    }

    /* ==========================================
       Header
    ========================================== */

    .app-modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 1.5rem;
        border-bottom: 1px solid #e5e7eb;
        background: #ffffff;
        flex-shrink: 0;
    }

        .app-modal-header h4 {
            font-size: 1.15rem;
            font-weight: 700;
            margin: 0;
        }

        .app-modal-header i {
            font-size: 1.4rem;
        }

    /* ==========================================
       Body
    ========================================== */

    .app-modal-body {
        flex: 1;
        overflow-y: auto;
        padding: 1.5rem;
        background: #fafbfc;
    }

    /* ==========================================
       Footer
    ========================================== */

    .app-modal-footer {
        display: flex;
        justify-content: flex-end;
        gap: .75rem;
        padding: 1rem 1.5rem;
        border-top: 1px solid #e5e7eb;
        background: #fff;
        flex-shrink: 0;
    }

        /* ==========================================
       Buttons
    ========================================== */

        .app-modal-footer .btn {
            min-width: 120px;
            border-radius: 10px;
            font-weight: 600;
        }

    /* ==========================================
       Close Button
    ========================================== */

    .btn-close {
        transition: .2s;
    }

        .btn-close:hover {
            transform: rotate(90deg);
        }

    /* ==========================================
       Scrollbar
    ========================================== */

    .app-modal-body::-webkit-scrollbar {
        width: 8px;
    }

    .app-modal-body::-webkit-scrollbar-track {
        background: transparent;
    }

    .app-modal-body::-webkit-scrollbar-thumb {
        background: #cbd5e1;
        border-radius: 50px;
    }

        .app-modal-body::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }

    /* ==========================================
       Animation
    ========================================== */

    @@keyframes modalFade {

        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    @@keyframes modalSlide {

        from {
            opacity: 0;
            transform: translateY(-25px) scale(.97);
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    /* ==========================================
       Responsive
    ========================================== */

    @@media (max-width: 1200px) {

        .modal-xl {
            width: 95%;
        }

        .modal-lg {
            width: 90%;
        }
    }

    @@media (max-width: 992px) {

        .modal-md,
        .modal-lg,
        .modal-xl {
            width: 95%;
        }
    }

    @@media (max-width: 768px) {

        .app-modal-backdrop {
            padding: .5rem;
        }

        .modal-sm,
        .modal-md,
        .modal-lg,
        .modal-xl {
            width: 100%;
            max-height: calc(100vh - 16px);
        }

        .app-modal-header {
            padding: 1rem;
        }

        .app-modal-body {
            padding: 1rem;
        }

        .app-modal-footer {
            padding: 1rem;
            flex-direction: column-reverse;
        }

            .app-modal-footer .btn {
                width: 100%;
            }
    }

    .ant-message {
        z-index: 1100;
    }
</style>

@if (Visible)
{
    <div class="app-modal-backdrop">

        <div class="app-modal @GetModalSize()">

            @* <!-- Header --> *@

            <div class="app-modal-header">

                <div class="d-flex align-items-center">

                    @if (!string.IsNullOrWhiteSpace(Icon))
                    {
                        <i class="@Icon me-2 text-primary fs-4"></i>
                    }

                    <h4 class="mb-0">

                        @Title

                    </h4>

                </div>

                @if (ShowCloseButton)
                {
                    <button class="btn-close"
                            @onclick="Cancel">
                    </button>
                }

            </div>

            @* <!-- Body --> *@

            <div class="app-modal-body">

                @ChildContent

            </div>

            @* <!-- Footer --> *@

            <div class="app-modal-footer">

                @if (FooterContent != null)
                {
                    @FooterContent
                }
                else
                {
                    <button class="btn btn-light"
                            disabled="@IsSaving"
                            @onclick="Cancel">

                        @CancelButtonText

                    </button>

                    <button class="btn btn-primary"
                            disabled="@IsSaving"
                            @onclick="Save">

                        @if (IsSaving)
                        {
                           <CustomButtonSpinner Label="Saving" />
                        }
                        else
                        {
                            
                            @SaveButtonText
                        }


                    </button>
                }

            </div>

        </div>

    </div>
}

@code
{
    [Parameter]
    public bool Visible { get; set; }

    [Parameter]
    public string Title { get; set; } = "";

    [Parameter]
    public string Icon { get; set; } = "bi bi-window";

    [Parameter]
    public CustomerModalSizeEnum Size { get; set; } = CustomerModalSizeEnum.Large;

    [Parameter]
    public bool IsSaving { get; set; }

    [Parameter]
    public bool ShowCloseButton { get; set; } = true;

    [Parameter]
    public string SaveButtonText { get; set; } = "Save";

    [Parameter]
    public string CancelButtonText { get; set; } = "Cancel";

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public RenderFragment? FooterContent { get; set; }

    [Parameter]
    public EventCallback OnSave { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    private async Task Save()
    {
        await OnSave.InvokeAsync();
    }

    private async Task Cancel()
    {
        await OnCancel.InvokeAsync();
    }

    private string GetModalSize()
    {
        return Size switch
        {
            CustomerModalSizeEnum.Small => "modal-sm",
            CustomerModalSizeEnum.Medium => "modal-md",
            CustomerModalSizeEnum.Large => "modal-lg",
            CustomerModalSizeEnum.ExtraLarge => "modal-xl",
            CustomerModalSizeEnum.FullScreen => "modal-full",
            _ => "modal-lg"
        };
    }
}