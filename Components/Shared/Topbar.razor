@using HospitalManagementSystem.Models.Auth
@inject HospitalManagementSystem.Interfaces.IAuth AuthStateSvc
@inject NavigationManager Navigation

<style>
    .topbar {
        height: 72px;
        background: #fff;
        border-bottom: 1px solid #e5e7eb;
        position: sticky;
        top: 0;
        z-index: 1030;
    }

    .topbar-btn {
        width: 46px;
        height: 46px;
        border-radius: 12px;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .notification-badge {
        position: absolute;
        top: 8px;
        right: 8px;
        font-size: .65rem;
    }

    .profile-btn {
        display: flex;
        align-items: center;
        gap: 12px;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 8px 14px;
        background: white;
    }

        .profile-btn:hover {
            background: #f8fafc;
        }

    .avatar {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        background: #2563eb;
        color: white;
        display: flex;
        justify-content: center;
        align-items: center;
        font-weight: 700;
    }

    .profile-info {
        text-align: left;
    }

        .profile-info small {
            color: #64748b;
        }

    .dropdown-menu {
        min-width: 220px;
        border-radius: 14px;
    }

    .dropdown-item {
        padding: 10px 18px;
    }

        .dropdown-item:hover {
            background: #f1f5f9;
        }

    @@media(max - width:768px) {

        .profile-info {
            display: none;
        }

        .profile-btn {
            padding: 6px;
        }

            .profile-btn i.bi-chevron-down {
                display: none;
            }
    }
</style>


<div class="topbar">

    <div class="d-flex align-items-center justify-content-between h-100 px-4">

        <!-- Left -->

        <div class="d-flex align-items-center">

            <!-- Mobile Menu -->

            <button class="btn btn-light d-lg-none me-3"
                    type="button"
                    data-bs-toggle="offcanvas"
                    data-bs-target="#sidebar">

                <i class="bi bi-list fs-4"></i>

            </button>

            <div>

                <h5 class="mb-0 fw-bold">

                    Hospital Management System

                </h5>

                @* <small class="text-muted">

                    @DateTime.Now.ToString("dddd, dd MMM yyyy")

                </small> *@

            </div>

        </div>

        <!-- Right -->

        <div class="d-flex align-items-center">

            <!-- Notification -->

            <button class="btn btn-light position-relative me-3 topbar-btn">

                <i class="bi bi-bell fs-5"></i>

                <span class="badge rounded-pill bg-danger notification-badge">

                    3

                </span>

            </button>

            <!-- User -->

            <div class="dropdown">

                <button class="btn btn-light profile-btn"
                        data-bs-toggle="dropdown">

                    <div class="avatar">

                        @GetInitials()

                    </div>

                    <div class="profile-info">

                        <div class="fw-semibold">

                            @($"{User.FirstName} {User.LastName}")

                        </div>

                        <small>

                            @User.Position

                        </small>

                    </div>

                    <i class="bi bi-chevron-down ms-2"></i>

                </button>

                <ul class="dropdown-menu dropdown-menu-end shadow border-0">

                    <li>

                        <a class="dropdown-item" href="/profile">

                            <i class="bi bi-person me-2"></i>

                            Profile

                        </a>

                    </li>

                    <li>

                        <a class="dropdown-item" href="/change-password">

                            <i class="bi bi-key me-2"></i>

                            Change Password

                        </a>

                    </li>

                    <li>
                        <hr class="dropdown-divider">
                    </li>

                    <li>

                        <button class="dropdown-item text-danger"
                                @onclick="Logout">

                            <i class="bi bi-box-arrow-right me-2"></i>

                            Logout

                        </button>

                    </li>

                </ul>

            </div>

        </div>

    </div>

</div>

@code {

    [Parameter]
    public MdUserInfo User { get; set; } = new();

    private string GetInitials()
    {
        if (string.IsNullOrWhiteSpace(User.FirstName))
            return "U";

        return $"{User.FirstName[0]}{User.LastName[0]}".ToUpper();
    }

    private async Task Logout()
    {
        await AuthStateSvc.LogoutAsync();

        Navigation.NavigateTo("/", true);
    }

}