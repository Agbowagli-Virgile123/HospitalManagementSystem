
<PageTitle>@PageTitle</PageTitle>

<style>
    .form-label {
        font-weight: 600;
        color: #374151;
    }

    .form-control,
    .form-select {
        height: 46px;
        border-radius: 10px;
        border: 1px solid #d1d5db;
    }

        .form-control:focus,
        .form-select:focus {
            box-shadow: none;
            border-color: #0d6efd;
        }

    h6 {
        color: #1f2937;
    }
</style>

<div class="container-fluid py-2">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="fw-bold mb-1">
                @PageTitle
            </h2>

            @if(PageTitle == "Dashboard")
            {
                <p class="text-muted mb-0">
                    Welcome back! Here's what's happening today.
                </p>
            }
            else if (PageTitle == "Patients")
            {
                <p class="text-muted mb-0">
                    Manage your patients and their records.
                </p>
            }
            else if (PageTitle == "Appointments")
            {
                <p class="text-muted mb-0">
                    Schedule and manage appointments.
                </p>
            }else if (PageTitle == "Doctors")
            {
                <p class="text-muted mb-0">
                    Manage your doctors and their schedules.
                </p>
            }
            else if (PageTitle == "Departments")
            {
                <p class="text-muted mb-0">
                    Manage hospital departments and services.
                </p>
            }
            else if (PageTitle == "Prescriptions")
            {
                <p class="text-muted mb-0">
                    Manage prescriptions.
                </p>
            }else if(PageTitle == "Medications")
            {
                <p class="text-muted">
                    Manage Medications.
                </p>
            }else if(PageTitle == "Billing")
            {
                <p class="text-muted">
                    Manage Billing.
                </p>
            }else if(PageTitle == "Reports")
            {
                <p class="text-muted">
                    View Reports.
                </p>
            }

        </div>

        <div>
            <span class="badge bg-primary fs-6">
                @DateTime.Now.ToString("dddd, dd MMMM yyyy")
            </span>
        </div>

    </div>

    @if(ChildContent != null)
    {
        @ChildContent
    }


</div>


@code{
    [Parameter] public string PageTitle { get; set; } = "Dashboard";
    [Parameter] public RenderFragment? ChildContent { get; set; }
}