    #region Stock Helpers

    private bool IsLowStock(MdGetMedication item)
    {
        return item.Quantity <= item.MinimumStock;
    }

    private bool IsExpired(MdGetMedication item)
    {
        return item.ExpiryDate.Date < DateTime.Today;
    }

    private bool IsExpiringSoon(MdGetMedication item)
    {
        return item.ExpiryDate <= DateTime.Today.AddMonths(3);
    }

    #endregion


    #region Close Modal

    private void CloseMedicationModal()
    {
        medication = new();

        isEdit = false;

        showMedicationModal = false;
    }

    #endregion


    #region Helpers

    private string GetStockBadge(MdGetMedication item)
    {
        if (IsExpired(item))
            return "danger";

        if (IsLowStock(item))
            return "warning";

        return "success";
    }

    private string GetStockText(MdGetMedication item)
    {
        if (IsExpired(item))
            return "Expired";

        if (IsLowStock(item))
            return "Low Stock";

        return "Available";
    }

    private string FormatCurrency(decimal amount)
    {
        return $"GH₵ {amount:N2}";
    }

    private string FormatDate(DateTime? date)
    {
        if (date == null)
            return "";

        return date.Value.ToString("dd MMM yyyy");
    }

    #endregion

}
