@page "/doctors"
@using HospitalManagementSystem.Components.Shared
@using HospitalManagementSystem.Components.Shared.Modal
@using HospitalManagementSystem.Models
@using HospitalManagementSystem.Models.Doctor
@layout HospitalManagementSystem.Components.Layout.MainLayout
@inject HospitalManagementSystem.Interfaces.IDoctor doctorService

<PageShell PageTitle="Doctors">

    <!-- Statistics -->

    <div class="row g-3 mb-4">

        <div class="col-lg-4 col-md-6">

            <div class="card border-0 shadow-sm h-100">

                <div class="card-body">

                    <div class="text-muted">
                        Total Doctors
                    </div>

                    <h2 class="fw-bold mt-2">
                       @totalDoctors
                    </h2>

                </div>

            </div>

        </div>

        <div class="col-lg-4 col-md-6">

            <div class="card border-0 shadow-sm h-100">

                <div class="card-body">

                    <div class="text-muted">
                        Available
                    </div>

                    <h2 class="fw-bold mt-2 text-success">
                       @availableDoctors
                    </h2>

                </div>

            </div>

        </div>

        <div class="col-lg-4 col-md-12">

            <div class="card border-0 shadow-sm h-100">

                <div class="card-body">

                    <div class="text-muted">
                        Unavailable
                    </div>

                    <h2 class="fw-bold mt-2 text-danger">
                        @unavailableDoctors 
                    </h2>

                </div>

            </div>

        </div>

    </div>

    <!-- Toolbar -->

    <PageToolbar SearchPlaceholder="Search doctors..."
                 AddButtonText="Add Doctor"
                 OnSearch="SearchDoctors"
                 OnAdd="OpenDoctorDialog"
                 OnRefresh="LoadDoctors" />

    <!-- Table -->

    <div class="card border-0 shadow-sm">

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">

                <thead class="table-light">

                    <tr>

                        <th>Name</th>

                        <th>Gender</th>

                        <th>Specialization</th>

                        <th>Phone</th>

                        <th>Fee</th>

                        <th>Status</th>

                        <th class="text-center">Action</th>

                    </tr>

                </thead>

                <tbody>

                    @if (isLoading)
                    {
                        @* show Spinner *@
                        <tr>
                            <td colspan="7" class="text-center py-5">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @if (doctors.Any())
                        {
                           @foreach(var doc in filtered)
                           {
                                <tr>

                                    <td>

                                        <div class="fw-semibold">
                                            @($"{doc.FirstName} {doc.LastName}")
                                        </div>

                                        <small class="text-muted">
                                            @doc.Email
                                        </small>

                                    </td>

                                    <td>@doc.Gender</td>

                                    <td>@doc.Specialization</td>

                                    <td>@doc.PhoneNumber</td>

                                    <td>GH₵ @doc.ConsultationFee</td>

                                    <td>

                                        @if(doc.IsAvailable == false)
                                        {
                                            <span class="badge bg-danger">
                                                Unavailable
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">
                                                Available
                                            </span>
                                        }

                                    </td>

                                    <td class="text-center">

                                        <button class="btn btn-sm btn-outline-primary me-2" @onclick="() => EditDoctor(doc)">

                                            <i class="bi bi-pencil-square"></i>

                                        </button>

                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteDoctor(doc)">

                                            <i class="bi bi-trash"></i>

                                        </button>

                                    </td>

                                </tr>
                                
                            }

                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5">
                                    <div class="fw-bold">
                                        No Doctor Found
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>

            </table>

        </div>

    </div>

</PageShell>

<AppModal
    Visible="@showDoctorModal"
        Title="@ModalTitle"
    Icon="bi bi-person-plus"
    Size="CustomerModalSizeEnum.Large"
    SaveButtonText="@SaveButtonText"
    IsSaving="@isSaving"
    OnSave="SaveDoctor"
    OnCancel="CloseDoctorModal">

    <div class="row g-4">

        <!-- Personal Information -->
        <div class="col-12">
            <h6 class="fw-bold border-bottom pb-2 mb-3">
                <i class="bi bi-person-badge me-2 text-primary"></i>
                Personal Information
            </h6>
        </div>

        <div class="col-md-6">
            <label class="form-label">
                First Name <span class="text-danger">*</span>
            </label>

            <input type="text" @bind-value="doctor.FirstName"
                   class="form-control"
                   placeholder="Enter first name" />
        </div>

        <div class="col-md-6">
            <label class="form-label">
                Last Name <span class="text-danger">*</span>
            </label>

            <input type="text"
                   class="form-control" @bind-value="doctor.LastName"
                   placeholder="Enter last name" />
        </div>

        <div class="col-md-6">
            <label class="form-label">
                Gender
            </label>

            <select class="form-select" @bind="doctor.Gender">
                <option>Select Gender</option>
                <option>Male</option>
                <option>Female</option>
            </select>
        </div>

        <div class="col-md-6">
            <label class="form-label">
                Department
            </label>

            <select class="form-select">
                <option value="">Select Department</option>
                @foreach (var department in departements)
                {
                    <option value="@department">@department</option>
                }
            </select>
        </div>

        <div class="col-md-6">
            <label class="form-label">
                Specialization
            </label>

            <input type="text"
                   class="form-control" @bind-value="doctor.Specialization"
                   placeholder="Specialization" />
        </div>

        <div class="col-md-6">
            <label class="form-label">
                License Number
            </label>

            <input type="text"
                   class="form-control" @bind-value="doctor.LicenseNumber"
                   placeholder="Medical License Number" />
        </div>

        <!-- Contact Information -->

        <div class="col-12 mt-2">
            <h6 class="fw-bold border-bottom pb-2 mb-3">
                <i class="bi bi-telephone me-2 text-success"></i>
                Contact Information
            </h6>
        </div>

        <div class="col-md-6">
            <label class="form-label">
                Phone Number
            </label>

            <input type="text"
                   class="form-control" @bind-value="doctor.PhoneNumber"
                   placeholder="024XXXXXXX" />
        </div>

        <div class="col-md-6">
            <label class="form-label">
                Email Address
            </label>

            <input type="email"
                   class="form-control" @bind-value="doctor.Email"
                   placeholder="doctor@hospital.com" />
        </div>

        <!-- Professional Information -->

        <div class="col-12 mt-2">
            <h6 class="fw-bold border-bottom pb-2 mb-3">
                <i class="bi bi-briefcase me-2 text-warning"></i>
                Professional Information
            </h6>
        </div>

        <div class="col-md-6">
            <label class="form-label">
                Consultation Fee (GH₵)
            </label>

            <input type="number" @bind-value="doctor.ConsultationFee"
                   class="form-control"
                   placeholder="0.00" />
        </div>

        <div class="col-md-6">
            <label class="form-label">
                Status
            </label>

            <select class="form-select" @bind="avalability">
                <option value="Available">Available</option>
                <option value="Unavailable">Unavailable</option>
            </select>
        </div>

    </div>

</AppModal>

@code{
    List<DoctorGet> doctors = new();
    List<DoctorGet> filtered = new();
    DoctorPost doctor = new();
    string selectedDoctorId = string.Empty;

    List<string> departements = new() { "Cardiology", "Pediatrics", "Surgery", "Neurology" };

    private bool showDoctorModal = false;
    bool isSaving = false;
    private bool isEdit;
    bool isLoading = true;
    double totalDoctors = 0;
    double availableDoctors = 0;
    double unavailableDoctors = 0;
    string avalability = "Available";

    private string ModalTitle =>
        isEdit ? "Update Doctor" : "Add Doctor";

    private string SaveButtonText =>
        isEdit ? "Update Doctor" : "Save Doctor";

    protected override async Task OnInitializedAsync()
    {
        await LoadDoctors();
    }


    //Load doctors from the service and update the statistics
    private async Task LoadDoctors()
    {
        isLoading = true;

        try
        {
            doctors = await doctorService.GetDoctorsAsync();
            filtered = doctors; // Initialize filtered list with all doctors
            totalDoctors = doctors.Count;
            availableDoctors = doctors.Count(d => d.IsAvailable == true);
            unavailableDoctors = doctors.Count(d => d.IsAvailable == false);

        }
        catch
        {
            // Handle exception (e.g., log it, show a message to the user)
            doctors = new List<DoctorGet>(); // Initialize to an empty list in case of error
            totalDoctors = 0;
            availableDoctors = 0;
            unavailableDoctors = 0;
        }
        finally
        {
            isLoading = false;
        }

    }


    //Get the doctor details for editing
    public void EditDoctor(DoctorGet doc)
    {
        if (doc == null || string.IsNullOrEmpty(doc.Id))
        {
            _message.Error("Invalid doctor ID.");
            return;
        }
        selectedDoctorId = doc.Id;
        doctor.FirstName = doc.FirstName;
        doctor.LastName = doc.LastName;
        doctor.ConsultationFee = doc.ConsultationFee;
        doctor.Email = doc.Email;
        doctor.ConsultationFee = doc.ConsultationFee;
        doctor.DepartementId = doc.DepartementId;
        doctor.Gender = doc.Gender;
        doctor.IsAvailable = doc.IsAvailable;
        doctor.Specialization = doc.Specialization;
        doctor.LicenseNumber = doc.LicenseNumber;
        doctor.PhoneNumber = doc.PhoneNumber;
        avalability = doc.IsAvailable ? "Available" : "Unavailable";

        isEdit = true;
        OpenDoctorDialog();

    }

    //Search doctors based on the search text
    private void SearchDoctors(string searchText)
    {
        filtered = doctors.Where(d => $"{d.FirstName} {d.LastName}".Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                                      d.Email.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                                      d.PhoneNumber.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                                      d.Specialization.Contains(searchText, StringComparison.OrdinalIgnoreCase)).ToList();
    }

    // Open the doctor modal for adding a new doctor
    private void OpenDoctorDialog()
    {
        showDoctorModal = true;

    }

    // Edit doctor or add new doctor

    private async Task SaveDoctor()
    {
        if(string.IsNullOrEmpty(doctor.FirstName) || string.IsNullOrEmpty(doctor.LastName))
        {
            _message.Error("First name and Last name are required.");
            return;
        }

        if (string.IsNullOrEmpty(doctor.Gender))
        {
            _message.Error("Gender is required.");
            return;
        }

        if (string.IsNullOrEmpty(doctor.Specialization))
        {
            _message.Error("Specialization is required.");
            return;
        }

        if (string.IsNullOrEmpty(doctor.PhoneNumber))
        {
            _message.Error("Phone number is required.");
            return;
        }

        if(string.IsNullOrEmpty(doctor.Email))
        {
            _message.Error("Email is required.");
            return;
        }

        if(string.IsNullOrEmpty(doctor.LicenseNumber))
        {
            _message.Error("License number is required.");
            return;
        }

        if(string.IsNullOrEmpty(avalability))
        {
            _message.Error("Availability status is required.");
            return;
        }else{

            doctor.IsAvailable = avalability == "Available";    
        }

        if(string.IsNullOrEmpty(doctor.ConsultationFee.ToString()) || doctor.ConsultationFee <= 0)
        {
            _message.Error("Consultation fee must be greater than zero.");
            return;
        }

        if (string.IsNullOrEmpty(doctor.DepartementId))
        {
            _message.Error("Department is required.");
            return;
        }

        isSaving = true;
        bool response = false;

        if (isEdit)
        {
            response = await doctorService.UpdateDoctorAsync(selectedDoctorId, doctor);
        }
        else
        {
            response = await doctorService.AddDoctorAsync(doctor);
        }

        if (!response)
        {
            if(isEdit)
                _message.Error("Failed to update doctor. Please try again.");
            else
            {
                
                _message.Error("Failed to save doctor. Please try again."); 
            }
            isSaving = false;
            return;
        }

        if(isEdit)
        {
            _message.Success("Doctor updated successfully.");
        }
        else
        {
            _message.Success("Doctor added successfully.");
        }
        CloseDoctorModal();
        await LoadDoctors();
        isSaving = false;

    }

    //Delete doctor
    public async Task DeleteDoctor(DoctorGet doc)
    {
        if(string.IsNullOrEmpty(doc.Id))
        {
            _message.Error("Invalid doctor ID.");
            return;
        }

        bool response = await doctorService.DeleteDoctorAsync(doc.Id);
        if (!response)
        {
            _message.Error("Failed to delete doctor. Please try again.");
            return;
        }
        _message.Success("Doctor deleted successfully.");
        await LoadDoctors();
    }

    // Close the doctor modal and reset the form

    private void CloseDoctorModal()
    {
        selectedDoctorId = string.Empty;
        doctor = new DoctorPost();
        isEdit = false;
        showDoctorModal = false;
    }
}