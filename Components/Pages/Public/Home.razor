@page "/"
@layout HospitalManagementSystem.Components.Layout.PublicLayout

<PageTitle>Home | @AppGlobal.AppName HMS</PageTitle>

<style>
    .hero-section {
        background: linear-gradient(135deg,#0d6efd,#0dcaf0) !important;
        padding: 80px 0;
    }

    .min-vh-75 {
        min-height: 75vh;
    }

    .hero-image {
        max-height: 550px;
    }

    .feature-card {
        border-radius: 20px;
        transition: .3s;
    }

        .feature-card:hover {
            transform: translateY(-8px);
        }

    .service-box {
        background: #fff;
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 8px 25px rgba(0,0,0,.08);
        text-align: center;
        transition: .3s;
    }

        .service-box:hover {
            transform: translateY(-8px);
        }

    .service-icon {
        font-size: 3rem;
        color: #0d6efd;
        margin-bottom: 20px;
    }

    .stats-section {
        background: #0d6efd;
        color: #fff;
        padding: 70px 0;
    }

        .stats-section h1 {
            font-size: 3rem;
            font-weight: 700;
        }

    .cta-box {
        background: #f8f9fa;
    }

    .btn {
        border-radius: 50px;
    }

    section {
        overflow: hidden;
    }

</style>

<!-- ================= HERO ================= -->
<section class="hero-section">
    <div class="container">
        <div class="row align-items-center min-vh-75">

            <div class="col-lg-6">

                <span class="badge bg-light text-primary px-3 py-2 mb-3">
                    Trusted Healthcare Services
                </span>

                <h1 class="display-4 fw-bold text-white mb-4">
                    Your Health Is <br />
                    Our Highest Priority
                </h1>

                <p class="lead text-light mb-4">
                    We provide quality healthcare services with experienced doctors,
                    modern medical equipment and compassionate patient care.
                </p>

                <div class="d-flex gap-3">

                    <a href="/appointment" class="btn btn-light btn-lg px-4">
                        <i class="bi bi-calendar-check me-2"></i>
                        Book Appointment
                    </a>

                    <a href="/login" class="btn btn-outline-light btn-lg px-4">
                        Staff Login
                    </a>

                </div>

            </div>

            <div class="col-lg-6 text-center mt-5 mt-lg-0">

                <img src="/assets/doctor.jpg"
                     class="img-fluid hero-image"
                     alt="Doctor" />

            </div>

        </div>
    </div>
</section>

<!-- ================= WHY US ================= -->

<section class="py-5 bg-light">

    <div class="container">

        <div class="text-center mb-5">

            <h2 class="fw-bold">
                Why Choose Us
            </h2>

            <p class="text-muted">
                Delivering excellent healthcare services for every patient.
            </p>

        </div>

        <div class="row g-4">

            <div class="col-md-4">

                <div class="card border-0 shadow-sm h-100 feature-card">

                    <div class="card-body text-center p-4">

                        <i class="bi bi-person-heart display-4 text-primary"></i>

                        <h4 class="mt-3">
                            Qualified Doctors
                        </h4>

                        <p class="text-muted">
                            Our experienced doctors provide quality medical care.
                        </p>

                    </div>

                </div>

            </div>

            <div class="col-md-4">

                <div class="card border-0 shadow-sm h-100 feature-card">

                    <div class="card-body text-center p-4">

                        <i class="bi bi-hospital display-4 text-success"></i>

                        <h4 class="mt-3">
                            Modern Facilities
                        </h4>

                        <p class="text-muted">
                            Equipped with advanced medical technology.
                        </p>

                    </div>

                </div>

            </div>

            <div class="col-md-4">

                <div class="card border-0 shadow-sm h-100 feature-card">

                    <div class="card-body text-center p-4">

                        <i class="bi bi-heart-pulse display-4 text-danger"></i>

                        <h4 class="mt-3">
                            Emergency Care
                        </h4>

                        <p class="text-muted">
                            Reliable emergency medical services available.
                        </p>

                    </div>

                </div>

            </div>

        </div>

    </div>

</section>

<!-- ================= SERVICES ================= -->

<section class="py-5">

    <div class="container">

        <div class="text-center mb-5">

            <h2 class="fw-bold">
                Our Services
            </h2>

            <p class="text-muted">
                We provide a wide range of healthcare services.
            </p>

        </div>

        <div class="row g-4">

            <div class="col-lg-4">

                <div class="service-box">

                    <i class="bi bi-clipboard2-pulse-fill service-icon"></i>

                    <h5>General Consultation</h5>

                    <p>
                        Medical consultation from experienced professionals.
                    </p>

                </div>

            </div>

            <div class="col-lg-4">

                <div class="service-box">

                    <i class="bi bi-capsule-pill service-icon"></i>

                    <h5>Medication</h5>

                    <p>
                        Proper prescriptions and medication management.
                    </p>

                </div>

            </div>

            <div class="col-lg-4">

                <div class="service-box">

                    <i class="bi bi-shield-check service-icon"></i>

                    <h5>Preventive Care</h5>

                    <p>
                        Regular health checkups and preventive treatment.
                    </p>

                </div>

            </div>

        </div>

    </div>

</section>

<!-- ================= STATISTICS ================= -->

<section class="stats-section">

    <div class="container">

        <div class="row text-center">

            <div class="col-md-3">

                <h1>25+</h1>

                <p>Doctors</p>

            </div>

            <div class="col-md-3">

                <h1>5,000+</h1>

                <p>Patients</p>

            </div>

            <div class="col-md-3">

                <h1>10+</h1>

                <p>Departments</p>

            </div>

            <div class="col-md-3">

                <h1>24/7</h1>

                <p>Emergency</p>

            </div>

        </div>

    </div>

</section>

<!-- ================= CTA ================= -->

<section class="py-5 bg-white">

    <div class="container">

        <div class="p-5 rounded-4 text-center cta-box">

            <h2 class="fw-bold">

                Need Medical Attention?

            </h2>

            <p class="mb-4">

                Schedule an appointment with one of our experienced healthcare professionals.

            </p>

            <a href="/appointment"
               class="btn btn-primary btn-lg px-5">

                Book Appointment

            </a>

        </div>

    </div>

</section>
