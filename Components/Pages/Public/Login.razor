@page "/login"
@using HospitalManagementSystem.Components.Shared
@using HospitalManagementSystem.Models.Auth
@layout HospitalManagementSystem.Components.Layout.EmptyLayout
@inject HospitalManagementSystem.Interfaces.IAuth authServices
@inject Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage.ProtectedLocalStorage ProtectedLocalStore

<PageTitle>Staff Login</PageTitle>


<style>
    .login-page {
        min-height: 100vh;
        background: linear-gradient(135deg,#0d6efd,#0dcaf0);
        /* padding: 2rem 1rem; */
    }

    .login-card {
        border-radius: 20px;
    }

    .login-logo {
        width: 90px;
        height: 90px;
        margin: auto;
        border-radius: 50%;
        background: #0d6efd;
        display: flex;
        justify-content: center;
        align-items: center;
        color: white;
        font-size: 2.5rem;
    }

    .input-group-text {
        background: #f8f9fa;
        border-right: none;
    }

    .form-control {
        border-left: none;
        height: 52px;
    }

        .form-control:focus {
            box-shadow: none;
        }

    .btn-primary {
        height: 52px;
        border-radius: 10px;
        font-weight: 600;
    }

    .card {
        overflow: hidden;
    }

    .form-check-input:checked {
        background-color: #0d6efd;
        border-color: #0d6efd;
    }
</style>

<div class="login-page">

    <div class="container">

        <div class="row justify-content-center align-items-center min-vh-100">

            <div class="col-lg-5 col-md-7">

                <div class="card border-0 shadow-lg login-card">

                    <div class="card-body p-5">

                        <div class="text-center mb-4">

                            <div class="login-logo mb-3">
                                <i class="bi bi-hospital-fill"></i>
                            </div>

                            <h2 class="fw-bold">
                                Staff Login
                            </h2>

                            <p class="text-muted">
                                Sign in to access the Hospital Management System
                            </p>

                        </div>

                        <div>

                            <div class="mb-3">

                                <label class="form-label fw-semibold">
                                    Access Code 
                                </label>

                                <div class="input-group">

                                    <span class="input-group-text">
                                        <i class="bi bi-person"></i>
                                    </span>

                                    <TextInput @bind-Value="req.AcccessCode" class="form-control"
                                               placeholder="Enter your Access Code" />

                                </div>

                            </div>

                            <div class="mb-3">

                                <label class="form-label fw-semibold">
                                    Password
                                </label>

                                <div class="input-group">

                                    <span class="input-group-text">
                                        <i class="bi bi-lock"></i>
                                    </span>

                                    <input type="password" @bind-value="req.Password"
                                               class="form-control"
                                               />

                                </div>

                            </div>

                            <div class="form-check mb-4">

                                <InputCheckbox @bind-Value="isChecked" class="form-check-input" />

                                <label class="form-check-label">

                                    Remember Me

                                </label>

                            </div>

                            <button class="btn btn-primary w-100 btn-lg" @onclick="HandleLogin" disabled="@isLoading">

                                @if (isLoading)
                                {
                                    <CustomButtonSpinner Label="Authenticating" />
                                    
                                }else{
                                <i class="bi bi-box-arrow-in-right me-2"> Sign In</i>

                               
                                }

                            </button>

                        </div>

                        <hr class="my-4">

                        <div class="text-center">

                            <a href="/"
                               class="text-decoration-none">

                                <i class="bi bi-arrow-left me-2"></i>

                                Return to Website

                            </a>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

@code{
    MdLogin req = new();

    bool isChecked = false;

    bool isLoading = false;

    private async Task HandleLogin()
    {

        if(string.IsNullOrEmpty(req.AcccessCode) || string.IsNullOrEmpty(req.Password))
        {
            _message.Error("Access Code and Password are required.");
            return;
        }

        isLoading = true;

        var resp = await authServices.Login(req);

        if(resp.response.ResponseCode != 1)
        {
            _message.Error(resp.response.ResponseMessage);
            req = new();
            isLoading = false;
            return;
        }

        _message.Success(resp.response.ResponseMessage);
        req = new();

        //Save user info in local storage
        await ProtectedLocalStore.SetAsync(AppGlobal.userInfoKey, resp.user);
        isLoading = false;

    }
}