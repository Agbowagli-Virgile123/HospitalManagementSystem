@page "/department"
@using HospitalManagementSystem.Components.Shared
@using HospitalManagementSystem.Components.Shared.Modal
@using HospitalManagementSystem.Models
@using HospitalManagementSystem.Models.Department
@using HospitalManagementSystem.Models.Doctor
@layout HospitalManagementSystem.Components.Layout.MainLayout
@inject HospitalManagementSystem.Interfaces.IDoctor doctorService
@inject IDepartment departmentService

<style>
    /* ==========================================
       Statistics Cards
    ========================================== */

    .icon-circle {
        width: 60px;
        height: 60px;
        border-radius: 16px;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .icon-circle i {
        font-size: 1.4rem;
    }

    .card {
        border-radius: 14px;
        transition: .25s ease;
    }

    .card:hover {
        transform: translateY(-2px);
        box-shadow: 0 .75rem 1.5rem rgba(0,0,0,.08) !important;
    }

    /* ==========================================
       Table
    ========================================== */

    .table {
        margin-bottom: 0;
    }

    .table thead th {
        background: #f8fafc;
        border-bottom: 2px solid #e9ecef;
        font-size: .9rem;
        font-weight: 700;
        color: #374151;
        white-space: nowrap;
    }

    .table tbody td {
        vertical-align: middle;
        padding: 1rem;
    }

    .table tbody tr {
        transition: .2s;
    }

    .table tbody tr:hover {
        background: #f8fbff;
    }

    .table tbody td small {
        display: block;
        margin-top: 4px;
        color: #6c757d;
    }

    /* ==========================================
       Buttons
    ========================================== */

    .btn-group {
        display: flex;
        gap: .4rem;
    }

    .btn-group .btn {
        width: 38px;
        height: 38px;
        border-radius: 10px;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .btn-group .btn i {
        font-size: .95rem;
    }

    .btn-outline-primary:hover {
        transform: translateY(-2px);
    }

    .btn-outline-info:hover {
        transform: translateY(-2px);
    }

    .btn-outline-danger:hover {
        transform: translateY(-2px);
    }

    /* ==========================================
       Badges
    ========================================== */

    .badge {
        font-size: .78rem;
        padding: .45rem .8rem;
        border-radius: 50px;
        font-weight: 600;
    }

    /* ==========================================
       Empty State
    ========================================== */

    .empty-state {
        padding: 70px 20px;
        text-align: center;
    }

    .empty-state i {
        font-size: 4rem;
        color: #cbd5e1;
    }

    .empty-state h5 {
        margin-top: 15px;
        font-weight: 700;
    }

    .empty-state p {
        color: #6c757d;
    }

    /* ==========================================
       Department Form
    ========================================== */

    .form-section {
        margin-bottom: 2rem;
    }

    .form-section-title {
        display: flex;
        align-items: center;
        gap: .6rem;
        font-size: 1rem;
        font-weight: 700;
        color: #1f2937;
        margin-bottom: 1rem;
        padding-bottom: .75rem;
        border-bottom: 1px solid #e5e7eb;
    }

    .form-section-title i {
        color: #0d6efd;
    }

    .form-label {
        font-weight: 600;
        margin-bottom: .45rem;
        color: #374151;
    }

    .form-control,
    .form-select,
    textarea {
        border-radius: 10px;
        border: 1px solid #d6d9de;
        min-height: 46px;
    }

    textarea.form-control {
        min-height: 120px;
    }

    .form-control:focus,
    .form-select:focus,
    textarea:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 .15rem rgba(13,110,253,.15);
    }

    /* ==========================================
       Assign Doctor Cards
    ========================================== */

    .doctor-card {
        border: 1px solid #dee2e6;
        border-radius: 14px;
        padding: 1rem;
        cursor: pointer;
        transition: .2s;
        margin-bottom: .75rem;
    }

    .doctor-card:hover {
        border-color: #0d6efd;
        background: #f8fbff;
    }

    .doctor-card.selected {
        border: 2px solid #0d6efd;
        background: #eaf3ff;
    }

    .doctor-avatar {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background: #0d6efd;
        color: white;
        font-size: 1.1rem;
        font-weight: bold;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    /* ==========================================
       Search Box
    ========================================== */

    .search-box {
        position: relative;
        margin-bottom: 1rem;
    }

    .search-box i {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: #6c757d;
    }

    .search-box input {
        padding-left: 40px;
    }

    /* ==========================================
       Responsive
    ========================================== */

    @@media (max-width:991px) {

        .btn-group {
            flex-wrap: wrap;
        }

        .table {
            min-width: 900px;
        }

        .icon-circle {
            width: 52px;
            height: 52px;
        }
    }

    @@media (max-width:768px) {

        .table tbody td {
            padding: .85rem;
        }

        .btn-group .btn {
            width: 34px;
            height: 34px;
        }

        .form-section-title {
            font-size: .95rem;
        }

        .doctor-card {
            padding: .85rem;
        }
    }</style>

<PageShell PageTitle="Departments">

    <!-- Statistics -->

    <div class="row g-3 mb-4">

        <div class="col-xl-3 col-md-6">

            <div class="card shadow-sm border-0 h-100">

                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>

                            <small class="text-muted">
                                Total Departments
                            </small>

                            <h3 class="fw-bold mt-2 mb-0">
                                @(filterd is not null ? filterd.Count() : 0)
                            </h3>

                        </div>

                        <div class="icon-circle bg-primary">

                            <i class="bi bi-building text-white"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-xl-3 col-md-6">

            <div class="card shadow-sm border-0 h-100">

                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>

                            <small class="text-muted">
                                Active
                            </small>

                            <h3 class="fw-bold text-success mt-2 mb-0">
                                @(filterd is not null ? filterd.Count(x=>x.DeptStatus=="Active") : 0)
                            </h3>

                        </div>

                        <div class="icon-circle bg-success">

                            <i class="bi bi-check-circle text-white"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-xl-3 col-md-6">

            <div class="card shadow-sm border-0 h-100">

                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>

                            <small class="text-muted">
                                Inactive
                            </small>

                            <h3 class="fw-bold text-danger mt-2 mb-0">
                                @(filterd is not null ? filterd.Count(x=>x.DeptStatus=="Inactive") : 0)
                            </h3>

                        </div>

                        <div class="icon-circle bg-danger">

                            <i class="bi bi-x-circle text-white"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-xl-3 col-md-6">

            <div class="card shadow-sm border-0 h-100">

                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>

                            <small class="text-muted">
                                Heads Assigned
                            </small>

                            <h3 class="fw-bold text-info mt-2 mb-0">
                                @(filterd is not null ? filterd.Count(x=> x is not null && x.HeadDoctor is not null && !string.IsNullOrWhiteSpace(x.HeadDoctor.Id)) : 0)
                            </h3>

                        </div>

                        <div class="icon-circle bg-info">

                            <i class="bi bi-person-check text-white"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <!-- Toolbar -->

    <PageToolbar

        SearchPlaceholder="Search department..."

        AddButtonText="Add Department"

        OnSearch="SearchDepartment"

        OnAdd="OpenAddDepartment"

        OnRefresh="LoadDepartments" />

    <!-- Table -->

    <div class="card shadow-sm border-0">

        <div class="card-body p-0">

            <div class="table-responsive">

                <table class="table table-hover align-middle mb-0">

                    <thead class="table-light">

                        <tr>

                            <th>Department</th>

                            <th>Location</th>

                            <th>Contact</th>

                            <th>Head of Department</th>

                            <th>Status</th>

                            <th width="260">Actions</th>

                        </tr>

                    </thead>

                    <tbody>

                        @if (Departments.Count == 0)
                        {
                            <tr>

                                <td colspan="6">

                                    <div class="text-center py-5">

                                        <i class="bi bi-building fs-1 text-muted"></i>

                                        <h5 class="mt-3">

                                            No Departments Found

                                        </h5>

                                    </div>

                                </td>

                            </tr>
                        }

                        else
                        {
                            @foreach (var dept in filterd!)
                            {
                                <tr>

                                    <td>

                                        <div class="fw-bold">

                                            @dept.DeptName

                                        </div>

                                        <small class="text-muted">

                                            @dept.DeptDescription

                                        </small>

                                    </td>

                                    <td>

                                        @dept.DeptLocation

                                    </td>

                                    <td>

                                        @dept.DeptContact

                                    </td>

                                    <td>

                                        @if(dept is null && string.IsNullOrWhiteSpace(dept!.HeadDoctor.Id))
                                        {
                                            <span class="text-danger">

                                                Not Assigned

                                            </span>
                                        }
                                        else
                                        {
                                            <span>

                                                @( dept.HeadDoctor is not null ? $"{dept.HeadDoctor.FirstName} {dept.HeadDoctor.LastName}" : "NA")

                                            </span>
                                        }

                                    </td>

                                    <td>

                                        @if(dept.DeptStatus=="Active")
                                        {
                                            <span class="badge bg-success">

                                                Active

                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">

                                                Inactive

                                            </span>
                                        }

                                    </td>

                                    <td>

                                        <div class="btn-group">

                                            <button class="btn btn-outline-primary btn-sm"

                                                    @onclick="(()=>OpenEditDepartment(dept))">

                                                <i class="bi bi-pencil-square"></i>

                                            </button>

                                            <button class="btn btn-outline-info btn-sm"

                                                    @onclick="(()=>AssignHead(dept))">

                                                <i class="bi bi-person-check"></i>

                                            </button>

                                            <button class="btn btn-outline-danger btn-sm"

                                                    @onclick="(()=>DeleteDepartment(dept.Id))">

                                                <i class="bi bi-trash"></i>

                                            </button>

                                        </div>

                                    </td>

                                </tr>
                            }
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</PageShell>

<!-- ===========================
     ADD / UPDATE MODAL
=========================== -->

<AppModal

    Visible="@showDepartmentModal"

    Title="@ModalTitle"

    Icon="bi bi-building"

    Size="CustomerModalSizeEnum.Large"

    SaveButtonText="@SaveButtonText"

    IsSaving="@isSaving"

    OnSave="SaveDepartment"

    OnCancel="CloseDepartmentModal">

    <!-- Department Form will go here -->
    <div class="row g-4">

        <div class="col-md-6">
            <label class="form-label">
                Departement Name <span class="text-danger">*</span>
            </label>

            <input type="text" @bind-value="department.DeptName"
                   class="form-control"
                   placeholder="Enter department name" />
        </div>

        <div class="col-md-6">
            <label class="form-label">
                Department Contact<span class="text-danger">*</span>
            </label>

            <input type="number"
                   class="form-control" @bind-value="department.DeptContact"
                   placeholder="Enter contact" />
        </div>

        <div class="col-md-6">
            <label class="form-label">
                Department Location<span class="text-danger">*</span>
            </label>

            <input type="text"
                   class="form-control" @bind-value="department.DeptLocation"
                   placeholder="Enter location" />
        </div>

        <div class="col-md-6">
            <label class="form-label">
                Status
            </label>

            <select class="form-select" @bind="department.DeptStatus">
                <option value="">Select Status</option>
                <option value="Active">Active</option>
                <option value="Inactive">Inactive</option>
            </select>
        </div>

        <div class="col-12">
            <label class="form-label">
                Description<span class="text-danger">*</span>
            </label>

            <textarea
                   class="form-control" @bind="department.DeptDescription"
                   placeholder="Enter Description" >
            </textarea>
        </div>

    </div>

</AppModal>

<!-- ===========================
     ASSIGN HEAD MODAL
=========================== -->

<AppModal

    Visible="@showAssignHeadModal"

    Title="Assign Head of Department"

    Icon="bi bi-person-check"

    Size="CustomerModalSizeEnum.Medium"

    SaveButtonText="Assign"

    IsSaving="@isSaving"

    OnSave="SaveHeadDoctor"

    OnCancel="CloseAssignHeadModal">

    <!-- Doctor Selection will go here -->
    <div class="row g-4">
        <div class="col">
            <label class="form-label">
                Doctors
            </label>

            <select class="form-select" @bind="selectedDoctorId">
                <option value="">Select Doctor</option>
                @foreach (var d in Doctors)
                {
                    <option value="@d.Id">@($"{d.FirstName} {d.LastName}")</option>
                }
            </select>
        </div>
    </div>

</AppModal>

@code {

    #region Variables

    private bool isLoading = true;
    private bool isSaving = false;

    private bool showDepartmentModal = false;
    private bool showAssignHeadModal = false;

    private bool isEdit = false;

    private string selectedDepartmentId = string.Empty;
    private string selectedDoctorId = string.Empty;

    private string searchText = string.Empty;

    private DepartmentPost department = new();

    private List<DepartmentGet> Departments = new();
    private IEnumerable<DepartmentGet> filterd => Departments.Where(d => d.DeptName.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                              d.DeptStatus.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                              d.DeptContact.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                              d.DeptLocation.Contains(searchText, StringComparison.OrdinalIgnoreCase)).ToList();

    private List<DoctorGet> Doctors = new();

    #endregion


    #region Computed Properties

    private string ModalTitle =>
        isEdit ? "Update Department" : "Add Department";

    private string SaveButtonText =>
        isEdit ? "Update Department" : "Save Department";

    #endregion


    #region Initialization

    protected override async Task OnInitializedAsync()
    {
        await LoadDepartments();
    }

    #endregion


    #region Load Data

    private async Task LoadDepartments()
    {
        // Load all departments

        isLoading = true;

        Departments = await departmentService.GetDepartments();

        isLoading = false;

    }

    private async Task LoadDoctors()
    {
        // Load doctors for Assign Head modal
        Doctors = await doctorService.GetDoctorsAsync();

    }

    #endregion


    #region Search

    private async Task SearchDepartment(string value)
    {
        searchText = value;

    }

    #endregion


    #region Add Department

    private void OpenAddDepartment()
    {
        // Clear model
        department = new DepartmentGet();

        // Set Edit = false
        isEdit = false;

        // Show modal
        showDepartmentModal = true;

    }

    #endregion


    #region Edit Department

    private async Task OpenEditDepartment(DepartmentGet item)
    {
        // Load department
        selectedDepartmentId = item.Id;
        department = new DepartmentPost
        {
            DeptName = item.DeptName ,
            DeptDescription = item.DeptDescription ,
            DeptLocation = item.DeptLocation,
            DeptContact = item.DeptContact,
            DeptStatus = item.DeptStatus,
        };

        // Set Edit = true
        isEdit = true;

        // Show modal
        showDepartmentModal = true;

    }

    #endregion


    #region Save Department

    private async Task SaveDepartment()
    {

        if (string.IsNullOrEmpty(department.DeptName))
        {
            _message.Error("Department name is required.");
            return;
        }

        if(string.IsNullOrEmpty(department.DeptStatus))
        {
            _message.Error("Department status is required.");
            return;
        }   

        if(string.IsNullOrEmpty(department.DeptLocation))
        {
            _message.Error("Department location is required.");
            return;
        }

        if(string.IsNullOrEmpty(department.DeptContact))
        {
            _message.Error("Department contact is required.");
            return;
        }

        if(string.IsNullOrEmpty(department.DeptDescription))
        {
            _message.Error("Department description is required.");
            return;
        }


        isSaving = true;
        bool response = false;
        try
        {
            if (isEdit)
            {
                if (string.IsNullOrEmpty(selectedDepartmentId))
                {
                    _message.Error("Department ID is missing for update."); 
                    isSaving = false;
                    return;
                }

                // Update Department
                response = await departmentService.UpdateDepartment(selectedDepartmentId, department);
            }
            else
            {
                // Create Department
                response = await departmentService.CreateDepartment(department);

            }

            if (!response)
            {
                if (isEdit)
                    _message.Error("Failed to update department. Please try again.");
                else
                {

                    _message.Error("Failed to save department. Please try again.");
                }
                isSaving = false;
                return;
            }

            if (isEdit)
            {
                _message.Success("Department updated successfully.");
            }
            else
            {
                _message.Success("Department added successfully.");
            }

            await LoadDepartments();

            CloseDepartmentModal();
        }
        finally
        {
            isSaving = false;
        }
    }

    #endregion


    #region Delete

    private async Task DeleteDepartment(string id)
    {
        // Confirmation
        if (string.IsNullOrEmpty(id))
        {
            _message.Error("Department is missing");
            return;
        }

        // Delete
        var (response, mesage) = await departmentService.DeleteDepartment(id); 
        if (!response)
        {
            _message.Error("Failed to delete department. Please try again.");
            return;
        }
        _message.Success("Department deleted successfully.");


        // Reload list
        await LoadDepartments();

    }

    #endregion


    #region Assign Head

    private async Task AssignHead(DepartmentGet item)
    {
        selectedDepartmentId = item.Id;

        selectedDoctorId = item.HeadDoctor is not null ? item.HeadDoctor.Id : "";

        await LoadDoctors();

        showAssignHeadModal = true;
    }

    private async Task SaveHeadDoctor()
    {
        // Save Head Doctor
        if(string.IsNullOrEmpty(selectedDepartmentId) || string.IsNullOrEmpty(selectedDoctorId))
        {
            _message.Error("Department or Doctor is required");
            return;
        }

        isSaving = true;

        var payload = new MapDepToDoc
            {
                DeptId = selectedDepartmentId,
                DocId = selectedDoctorId
            };
        // Delete
        var response = await departmentService.MapDepartmentHead(payload);
        if (!response)
        {
            _message.Error("Failed to map. Please try again.");
            return;
        }
        _message.Success("Mapped successfully.");


        // Reload list
        await LoadDepartments();

        // Reload departments

        CloseAssignHeadModal();
    }

    #endregion


    #region Modal

    private void CloseDepartmentModal()
    {
        showDepartmentModal = false;
        selectedDepartmentId = string.Empty;
        department = new();

        isEdit = false;
    }

    private void CloseAssignHeadModal()
    {
        showAssignHeadModal = false;

        selectedDepartmentId = "";

        selectedDoctorId = "";
    }

    #endregion


    #region Utilities

    private string GetStatusBadge(string status)
    {
        return status switch
        {
            "Active" => "success",
            "Inactive" => "danger",
            _ => "secondary"
        };
    }

    private string GetDoctorInitials(string fullName)
    {
        if (string.IsNullOrWhiteSpace(fullName))
            return "?";

        var names = fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);

        if (names.Length == 1)
            return names[0][0].ToString().ToUpper();

        return $"{names[0][0]}{names[1][0]}".ToUpper();
    }

    #endregion
}