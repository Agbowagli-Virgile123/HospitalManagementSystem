@page "/patients"
@layout HospitalManagementSystem.Components.Layout.MainLayout
@using HospitalManagementSystem.Components.Shared
@using HospitalManagementSystem.Components.Shared.Modal
@using HospitalManagementSystem.Models
@using HospitalManagementSystem.Models.Patients

<style>
    /* ===========================================
       Statistics Cards
    =========================================== */

    .icon-circle {
        width: 58px;
        height: 58px;
        border-radius: 14px;
        display: flex;
        justify-content: center;
        align-items: center;
    }

        .icon-circle i {
            font-size: 1.4rem;
        }

    .card {
        border-radius: 14px;
        transition: all .25s ease;
    }

        .card:hover {
            transform: translateY(-3px);
            box-shadow: 0 .75rem 1.5rem rgba(0,0,0,.08) !important;
        }

    /* ===========================================
       Table
    =========================================== */

    .table {
        margin-bottom: 0;
    }

        .table thead th {
            background: #f8fafc;
            color: #374151;
            font-weight: 700;
            font-size: .92rem;
            border-bottom: 2px solid #e5e7eb;
            white-space: nowrap;
        }

        .table tbody td {
            padding: 1rem;
            vertical-align: middle;
        }

        .table tbody tr {
            transition: .2s;
        }

            .table tbody tr:hover {
                background: #f8fbff;
            }

    /* ===========================================
       Patient Avatar
    =========================================== */

    .avatar {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        background: linear-gradient(135deg,#0d6efd,#3b82f6);
        color: white;
        display: flex;
        justify-content: center;
        align-items: center;
        font-weight: 700;
        font-size: 1rem;
        box-shadow: 0 4px 12px rgba(13,110,253,.25);
    }

    /* ===========================================
       Buttons
    =========================================== */

    .btn-group {
        display: flex;
        gap: .4rem;
    }

        .btn-group .btn {
            width: 38px;
            height: 38px;
            border-radius: 10px;
            display: flex;
            justify-content: center;
            align-items: center;
            transition: .2s;
        }

            .btn-group .btn:hover {
                transform: translateY(-2px);
            }

    /* ===========================================
       Badges
    =========================================== */

    .badge {
        padding: .45rem .8rem;
        border-radius: 50px;
        font-weight: 600;
        font-size: .78rem;
    }

    /* ===========================================
       Empty State
    =========================================== */

    .empty-state {
        padding: 70px 20px;
        text-align: center;
    }

        .empty-state i {
            font-size: 4rem;
            color: #cbd5e1;
        }

        .empty-state h5 {
            font-weight: 700;
            margin-top: 15px;
        }

        .empty-state p {
            color: #6b7280;
        }

    /* ===========================================
       Modal Sections
    =========================================== */

    .form-section {
        margin-bottom: 2rem;
    }

    .form-section-title {
        display: flex;
        align-items: center;
        gap: .75rem;
        font-weight: 700;
        font-size: 1rem;
        color: #1f2937;
        padding-bottom: .75rem;
        margin-bottom: 1.25rem;
        border-bottom: 1px solid #e5e7eb;
    }

        .form-section-title i {
            color: #0d6efd;
            font-size: 1.1rem;
        }

    /* ===========================================
       Form Controls
    =========================================== */

    .form-label {
        font-weight: 600;
        color: #374151;
        margin-bottom: .45rem;
    }

    .form-control,
    .form-select {
        min-height: 46px;
        border-radius: 10px;
        border: 1px solid #d1d5db;
        transition: all .2s;
    }

    textarea.form-control {
        min-height: 110px;
        resize: vertical;
    }

    .form-control:focus,
    .form-select:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 .15rem rgba(13,110,253,.15);
    }

    /* ===========================================
       Readonly Controls
    =========================================== */

    .form-control:read-only {
        background: #f8f9fa;
    }

    /* ===========================================
       Required Field
    =========================================== */

    .required::after {
        content: " *";
        color: red;
    }

    /* ===========================================
       Responsive
    =========================================== */

    @@media (max-width:992px) {

        .table {
            min-width: 1050px;
        }

        .btn-group {
            flex-wrap: wrap;
        }
    }

    @@media (max-width:768px) {

        .avatar {
            width: 42px;
            height: 42px;
            font-size: .9rem;
        }

        .icon-circle {
            width: 50px;
            height: 50px;
        }

        .table tbody td {
            padding: .85rem;
        }

        .btn-group .btn {
            width: 34px;
            height: 34px;
        }

        .form-section-title {
            font-size: .95rem;
        }
    }

    @@media (max-width:576px) {

        .card-body {
            padding: 1rem;
        }

        .form-control,
        .form-select {
            min-height: 44px;
        }
    }
</style>
<PageShell PageTitle="Patients">

    <!-- ============================= -->
    <!-- Statistics -->
    <!-- ============================= -->

    <div class="row g-3 mb-4">

        <div class="col-xl-3 col-md-6">

            <div class="card shadow-sm border-0 h-100">

                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>

                            <small class="text-muted">

                                Total Patients

                            </small>

                            <h3 class="fw-bold mt-2">

                                @Patients.Count

                            </h3>

                        </div>

                        <div class="icon-circle bg-primary">

                            <i class="bi bi-people-fill text-white"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-xl-3 col-md-6">

            <div class="card shadow-sm border-0 h-100">

                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>

                            <small class="text-muted">

                                Male

                            </small>

                            <h3 class="fw-bold text-primary mt-2">

                                @(filtered is not null ? Patients.Count(x=>x.Gender=="Male") : 0)

                            </h3>

                        </div>

                        <div class="icon-circle bg-info">

                            <i class="bi bi-gender-male text-white"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-xl-3 col-md-6">

            <div class="card shadow-sm border-0 h-100">

                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>

                            <small class="text-muted">

                                Female

                            </small>

                            <h3 class="fw-bold text-danger mt-2">

                                @(filtered is not null ?Patients.Count(x=>x.Gender=="Female") : 0)

                            </h3>

                        </div>

                        <div class="icon-circle bg-danger">

                            <i class="bi bi-gender-female text-white"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-xl-3 col-md-6">

            <div class="card shadow-sm border-0 h-100">

                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>

                            <small class="text-muted">

                                Active Patients

                            </small>

                            <h3 class="fw-bold text-success mt-2">

                                @(filtered is not null ? Patients.Count(x=>x.Status=="Active") : 0)

                            </h3> 

                        </div>

                        <div class="icon-circle bg-success">

                            <i class="bi bi-heart-pulse-fill text-white"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <!-- ============================= -->
    <!-- Toolbar -->
    <!-- ============================= -->

    <PageToolbar

        SearchPlaceholder="Search patient..."

        AddButtonText="Register Patient"

        OnSearch="SearchPatient"

        OnAdd="OpenAddPatient"

        OnRefresh="LoadPatients"/>

    <!-- ============================= -->
    <!-- Table -->
    <!-- ============================= -->

    <div class="card shadow-sm border-0">

        <div class="card-body p-0">

            <div class="table-responsive">

                <table class="table table-hover align-middle mb-0">

                    <thead class="table-light">

                        <tr>

                            <th width="70"></th>

                            <th>Patient</th>

                            <th>Gender</th>

                            <th>Phone</th>

                            @* <th>Blood Group</th> *@

                            <th>Age</th>

                            <th>Status</th>

                            <th width="300">

                                Actions

                            </th>

                        </tr>

                    </thead>

                    <tbody>

                        @if(Patients.Count == 0)
                        {
                            <tr>

                                <td colspan="8">

                                    <div class="text-center py-5">

                                        <i class="bi bi-people fs-1 text-muted"></i>

                                        <h5 class="mt-3">

                                            No Patients Found

                                        </h5>

                                    </div>

                                </td>

                            </tr>
                        }

                        else
                        {
                            @foreach(var patient in Patients)
                            {
                                <tr>

                                    <td>

                                        <div class="avatar">

                                            @GetInitials(patient.FirstName,patient.LastName)

                                        </div>

                                    </td>

                                    <td>

                                        <div class="fw-bold">

                                            @patient.FirstName @patient.LastName

                                        </div>

                                        <small class="text-muted">

                                            @patient.PhoneNumber

                                        </small>

                                    </td>

                                    <td>

                                        @patient.Gender

                                    </td>

                                    <td>

                                        @patient.PhoneNumber

                                    </td>

                                    @* <td>

                                        @patient.BloodGroup

                                    </td> *@

                                    <td>

                                        @(DateTime.Now.Year - patient.DOB.Year) Years
                                    </td>

                                    <td>

                                        @if(patient.Status=="Active")
                                        {
                                            <span class="badge bg-success">

                                                Active

                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">

                                                Inactive

                                            </span>
                                        }

                                    </td>

                                    <td>

                                        <div class="btn-group">

                                            <button class="btn btn-outline-primary btn-sm"
                                                    title="Edit"

                                                    @onclick="(()=>EditPatient(patient))">

                                                <i class="bi bi-pencil-square"></i>

                                            </button>

                                            <button class="btn btn-outline-success btn-sm"
                                                    title="Medical Record">

                                                <i class="bi bi-file-medical"></i>

                                            </button>

                                            <button class="btn btn-outline-warning btn-sm"
                                                    title="Billing">

                                                <i class="bi bi-cash-stack"></i>

                                            </button>

                                            <button class="btn btn-outline-danger btn-sm"
                                                    title="Delete"

                                                    @onclick="(()=>DeletePatient(patient.Id))">

                                                <i class="bi bi-trash"></i>

                                            </button>

                                        </div>

                                    </td>

                                </tr>
                            }
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</PageShell>


 <AppModal

    Visible="@showPatientModal"

    Title="@ModalTitle"

    Icon="bi bi-person-plus"

    Size="CustomerModalSizeEnum.ExtraLarge"

    SaveButtonText="@SaveButtonText"

    IsSaving="@isSaving"

    OnSave="SavePatient"

    OnCancel="ClosePatientModal">

    <div class="container-fluid">

        <!-- ========================================= -->
        <!-- Personal Information -->
        <!-- ========================================= -->

        <div class="form-section">

            <div class="form-section-title">

                <i class="bi bi-person-circle"></i>

                Personal Information

            </div>

            <div class="row g-3">

                <div class="col-md-6">

                    <label class="form-label">

                        First Name

                    </label>

                    <input class="form-control" @bind-value="patient.FirstName"
                           placeholder="First Name" />

                </div>

                <div class="col-md-6">

                    <label class="form-label">

                        Last Name

                    </label>

                    <input class="form-control" @bind-value="patient.LastName"
                           placeholder="Last Name" />

                </div>

                <div class="col-md-4">

                    <label class="form-label">

                        Gender

                    </label>

                    <select class="form-select" @bind="patient.Gender">

                        <option>Male</option>

                        <option>Female</option>

                    </select>

                </div>

                <div class="col-md-4">

                    <label class="form-label">

                        Date of Birth

                    </label>

                    <input type="date"
                           class="form-control" @bind-value="patient.DOB" />

                </div>

                <div class="col-md-4">

                    <label class="form-label">

                        Nationality

                    </label>

                    <input class="form-control" @bind-value="patient.Nationality"
                           placeholder="Nationality" />

                </div>

            </div>

        </div>

        <!-- ========================================= -->
        <!-- Contact -->
        <!-- ========================================= -->

        <div class="form-section mt-4">

            <div class="form-section-title">

                <i class="bi bi-telephone"></i>

                Contact Information

            </div>

            <div class="row g-3">

                <div class="col-md-6">

                    <label class="form-label">

                        Phone Number

                    </label>

                    <input type="number" class="form-control" @bind-value="patient.PhoneNumber"
                           placeholder="024xxxxxxx" />

                </div>

                <div class="col-md-6">

                    <label class="form-label">

                        Email Address

                    </label>

                    <input class="form-control" @bind-value="patient.Email"
                           placeholder="example@mail.com" />

                </div>

                <div class="col-md-6">

                    <label class="form-label">

                        Emergency Name

                    </label>

                    <input class="form-control" @bind-value="patient.EmergencyName"
                           placeholder="Emergency Name" />

                </div>

                <div class="col-md-6">

                    <label class="form-label">

                        Emergency Contact

                    </label>

                    <input class="form-control" @bind-value="patient.EmergencyContactPhone"
                           placeholder="Emergency Contact" />

                </div>

            </div>

        </div>

        <!-- ========================================= -->
        <!-- Medical -->
        <!-- ========================================= -->

        <div class="form-section mt-4">

            <div class="form-section-title">

                <i class="bi bi-heart-pulse"></i>

                Medical Information

            </div>

            <div class="row g-3">

                <div class="col-md-4">

                    <label class="form-label">

                        Blood Group

                    </label>

                    <select class="form-select" @bind="patient.BloodGroup">

                        <option>A+</option>
                        <option>A-</option>
                        <option>B+</option>
                        <option>B-</option>
                        <option>AB+</option>
                        <option>AB-</option>
                        <option>O+</option>
                        <option>O-</option>

                    </select>

                </div>

                <div class="col-md-4">

                    <label class="form-label">

                        Marital Status

                    </label>

                    <select class="form-select" @bind="patient.MaritalStatus">

                        <option>Single</option>
                        <option>Married</option>

                    </select>

                </div>

                <div class="col-md-4">

                    <label class="form-label">

                        Status

                    </label>

                    <select class="form-select" @bind="patient.Status">

                        <option>Active</option>

                        <option>Inactive</option>

                    </select>

                </div>

                <div class="col-12">

                    <label class="form-label">

                        Allergies

                    </label>

                    <textarea class="form-control" @bind="patient.AllergyDescription"
                              rows="2"
                              placeholder="Any allergies..."></textarea>

                </div>

            </div>

        </div>

        <!-- ========================================= -->
        <!-- Address -->
        <!-- ========================================= -->

        <div class="form-section mt-4">

            <div class="form-section-title">

                <i class="bi bi-geo-alt"></i>

                Address Information

            </div>

            <div class="row g-3">

                <div class="col-md-6">

                    <label class="form-label">

                        City

                    </label>

                    <input class="form-control" @bind-value="patient.City"
                           placeholder="City" />

                </div>

                <div class="col-md-6">

                    <label class="form-label">

                        Country

                    </label>

                    <input class="form-control" @bind-value="patient.Country"
                           placeholder="Country" />

                </div>

                <div class="col-12">

                    <label class="form-label">

                        Residential Address

                    </label>

                    <textarea class="form-control" @bind="patient.Address"
                              rows="3"
                              placeholder="Address"></textarea>

                </div>

            </div>

        </div>

    </div>

</AppModal>

@code {

    #region Variables

    private bool isLoading = true;
    private bool isSaving = false;

    private bool showPatientModal = false;

    private bool isEdit = false;

    private string searchText = string.Empty;

