    {
        searchText = keyword;

        // Search Patients

        // Patients = await PatientService.Search(keyword);

    }

    #endregion


    #region Add Patient

    private void OpenAddPatient()
    {
        isEdit = false;

        patient = new();

        showPatientModal = true;
    }

    #endregion


    #region Edit Patient

    private async Task EditPatient(MdGetPatient item)
    {
        isEdit = true;

        // Get Patient By Id

        // patient = await PatientService.Get(item.Id);

        patient = item;

        showPatientModal = true;
    }

    #endregion


    #region Save Patient

    private async Task SavePatient()
    {
        isSaving = true;

        try
        {

            if (isEdit)
            {
                // Update Patient

                // await PatientService.Update(patient);

            }
            else
            {
                // Create Patient

                // await PatientService.Create(patient);

            }

            await LoadPatients();

            ClosePatientModal();

        }
        catch (Exception ex)
        {

            Console.WriteLine(ex.Message);

        }
        finally
        {

            isSaving = false;

        }

    }

    #endregion


    #region Delete

    private async Task DeletePatient(string id)
    {

        // Confirmation Dialog

        // await PatientService.Delete(id);

        await LoadPatients();

    }

    #endregion


    #region Close Modal

    private void ClosePatientModal()
    {

        showPatientModal = false;

        patient = new();

        isEdit = false;

    }

    #endregion


    #region Helpers

    private string GetInitials(string firstName, string lastName)
    {

        string initials = "";

        if (!string.IsNullOrWhiteSpace(firstName))
            initials += firstName[0];

        if (!string.IsNullOrWhiteSpace(lastName))
            initials += lastName[0];

        return initials.ToUpper();

    }

    private int CalculateAge(DateTime dob)
    {

        var age = DateTime.Today.Year - dob.Year;

        if (dob.Date > DateTime.Today.AddYears(-age))
            age--;

        return age;

    }

    private string GetStatusBadge(string status)
    {

        return status switch
        {
            "Active" => "success",
            "Inactive" => "danger",
            _ => "secondary"
        };

    }

    #endregion

