                            d.Gender.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                            d.Status.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                            d.PhoneNumber.Contains(searchText, StringComparison.OrdinalIgnoreCase)).ToList();
    #endregion


    #region Computed Properties

    private string ModalTitle =>
        isEdit ? "Update Patient" : "Register Patient";

    private string SaveButtonText =>
        isEdit ? "Update Patient" : "Register Patient";

    #endregion


    #region Initialization

    protected override async Task OnInitializedAsync()
    {
        await LoadPatients();
    }

    #endregion


    #region Load Patients

    private async Task LoadPatients()
    {
        isLoading = true;

        try
        {
            // Call API

            // Patients = await PatientService.GetPatients();

        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    #endregion


    #region Search

