@page "/dashboard"
@using HospitalManagementSystem.Components.Shared
@using HospitalManagementSystem.Models.Appointment
@using HospitalManagementSystem.Models.Dashboard
@layout HospitalManagementSystem.Components.Layout.MainLayout
@inject HospitalManagementSystem.Interfaces.IDashboard dashboardService
@inject HospitalManagementSystem.Services.IAppointmentService appointmentService

<style>
    .dashboard-card {
        border-radius: 18px;
        transition: .3s;
    }

        .dashboard-card:hover {
            transform: translateY(-5px);
        }

    .icon-box {
        width: 60px;
        height: 60px;
        border-radius: 15px;
        display: flex;
        justify-content: center;
        align-items: center;
        color: white;
        font-size: 1.6rem;
    }

    .table th {
        font-weight: 600;
    }

    .card {
        border-radius: 18px;
    }

    .card-header {
        border-bottom: 1px solid #eee;
        font-weight: 600;
    }

    .btn {
        border-radius: 10px;
    }</style>

<PageShell PageTitle="Dashboard">
    <!-- Statistics -->

    <div class="row g-4 mb-4">

        <div class="col-lg-3 col-md-6">

            <div class="card dashboard-card border-0 shadow-sm">

                <div class="card-body">

                    <div class="d-flex justify-content-between">

                        <div>

                            <small class="text-muted">
                                Doctors
                            </small>

                            <h2 class="fw-bold mt-2">
                                @summary.TotalDoctors
                            </h2>

                        </div>

                        <div class="icon-box bg-primary">

                            <i class="bi bi-person-badge"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-lg-3 col-md-6">

            <div class="card dashboard-card border-0 shadow-sm">

                <div class="card-body">

                    <div class="d-flex justify-content-between">

                        <div>

                            <small class="text-muted">
                                Patients
                            </small>

                            <h2 class="fw-bold mt-2">
                                @summary.TotalPatients
                            </h2>

                        </div>

                        <div class="icon-box bg-success">

                            <i class="bi bi-people"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-lg-3 col-md-6">

            <div class="card dashboard-card border-0 shadow-sm">

                <div class="card-body">

                    <div class="d-flex justify-content-between">

                        <div>

                            <small class="text-muted">
                                Appointments
                            </small>

                            <h2 class="fw-bold mt-2">
                                @summary.TotalAppointments
                            </h2>

                        </div>

                        <div class="icon-box bg-warning">

                            <i class="bi bi-calendar-check"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-lg-3 col-md-6">

            <div class="card dashboard-card border-0 shadow-sm">

                <div class="card-body">

                    <div class="d-flex justify-content-between">

                        <div>

                            <small class="text-muted">
                                Revenue
                            </small>

                            <h2 class="fw-bold mt-2">
                                @summary.TotalRevenue.ToString("N2")
                            </h2>

                        </div>

                        <div class="icon-box bg-danger">

                            <i class="bi bi-cash-stack"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <!-- Appointment Status -->

    <div class="row g-4 mb-4">

        <div class="col-lg-3">

            <div class="card border-0 shadow-sm">

                <div class="card-body text-center">

                    <h4 class="text-primary fw-bold">
                        @summary.TodayAppointments
                    </h4>

                    <div>Today's Appointments</div>

                </div>

            </div>

        </div>

        <div class="col-lg-3">

            <div class="card border-0 shadow-sm">

                <div class="card-body text-center">

                    <h4 class="text-warning fw-bold">
                       @summary.PendingAppointments
                    </h4>

                    <div>Pending</div>

                </div>

            </div>

        </div>

        <div class="col-lg-3">

            <div class="card border-0 shadow-sm">

                <div class="card-body text-center">

                    <h4 class="text-success fw-bold">
                        @summary.CompletedAppointments
                    </h4>

                    <div>Completed</div>

                </div>

            </div>

        </div>

        <div class="col-lg-3">

            <div class="card border-0 shadow-sm">

                <div class="card-body text-center">

                    <h4 class="text-danger fw-bold">
                       @summary.CancelledAppointments
                    </h4>

                    <div>Cancelled</div>

                </div>

            </div>

        </div>

    </div>

    <!-- Tables -->

    <div class="row">

        <!-- Recent Appointments -->

        <div class="col-lg-8 mb-4">

            <div class="card border-0 shadow-sm">

                <div class="card-header bg-white">

                    <h5 class="mb-0">
                        Recent Appointments
                    </h5>

                </div>

                <div class="card-body p-0">

                    <table class="table table-hover mb-0">

                        <thead class="table-light">

                            <tr>

                                <th>Patient</th>

                                <th>Doctor</th>

                                <th>Date</th>

                                <th>Time</th>

                                <th>Status</th>

                            </tr>

                        </thead>

                        <tbody>

                            @if (recentAppointments.Any())
                            {
                                
                                @foreach (var appointment in recentAppointments)
                            {
                                <tr>
                                    <td>@appointment.PatientName</td>
                                    <td>@appointment.DoctorName</td>
                                    <td>@appointment.Date</td>
                                    <td>@appointment.Time</td>
                                    <td>
                                        @if (appointment.Status == "Pending")
                                        {
                                            <span class="badge bg-warning">
                                                Pending
                                            </span>
                                        }
                                        else if (appointment.Status == "Completed")
                                        {
                                            <span class="badge bg-success">
                                                Completed
                                            </span>
                                        }
                                        else if (appointment.Status == "Cancelled")
                                        {
                                            <span class="badge bg-danger">
                                                Cancelled
                                            </span>
                                        }
                                    </td>
                                </tr>
                            }
                            }else{
                                <tr>
                                    <td colspan="5" class="text-center">
                                        No recent appointments found.
                                    </td>
                                </tr>
                            }


                        </tbody>

                    </table>

                </div>

            </div>

        </div>

        <!-- Quick Actions -->

        <div class="col-lg-4">

            <div class="card border-0 shadow-sm mb-4">

                <div class="card-header bg-white">

                    <h5 class="mb-0">
                        Quick Actions
                    </h5>

                </div>

                <div class="card-body d-grid gap-3">

                    <a href="/doctors" class="btn btn-outline-primary">
                        <i class="bi bi-person-plus me-2"></i>
                        Add Doctor
                    </a>

                    <a href="/patients" class="btn btn-outline-success">
                        <i class="bi bi-person-plus-fill me-2"></i>
                        Register Patient
                    </a>

                    <a href="/appointments" class="btn btn-outline-warning">
                        <i class="bi bi-calendar-plus me-2"></i>
                        Schedule Appointment
                    </a>

                    <a href="/billing" class="btn btn-outline-danger">
                        <i class="bi bi-receipt me-2"></i>
                        Generate Bill
                    </a>

                </div>

            </div>

        </div>

    </div>
</PageShell>

@code{
    DashboardSummary summary = new();
    List<RecentAppointment> recentAppointments = new();
    bool isLoading = true;
    DateTime date = DateTime.Now;

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        try
        {
            summary = await dashboardService.GetDashboardSummaryAsync();
            recentAppointments = await appointmentService.GetRecentAppointmentsAsync(date, date);

        }
        catch
        {
            summary = new();
            recentAppointments = new();

        }
        finally
        {
            isLoading = false;
            
        }
    }


}