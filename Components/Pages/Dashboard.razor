@page "/dashboard"
@using HospitalManagementSystem.Components.Shared
@layout HospitalManagementSystem.Components.Layout.MainLayout

<style>
    .dashboard-card {
        border-radius: 18px;
        transition: .3s;
    }

        .dashboard-card:hover {
            transform: translateY(-5px);
        }

    .icon-box {
        width: 60px;
        height: 60px;
        border-radius: 15px;
        display: flex;
        justify-content: center;
        align-items: center;
        color: white;
        font-size: 1.6rem;
    }

    .table th {
        font-weight: 600;
    }

    .card {
        border-radius: 18px;
    }

    .card-header {
        border-bottom: 1px solid #eee;
        font-weight: 600;
    }

    .btn {
        border-radius: 10px;
    }</style>

<PageShell PageTitle="Dashboard">
    <!-- Statistics -->

    <div class="row g-4 mb-4">

        <div class="col-lg-3 col-md-6">

            <div class="card dashboard-card border-0 shadow-sm">

                <div class="card-body">

                    <div class="d-flex justify-content-between">

                        <div>

                            <small class="text-muted">
                                Doctors
                            </small>

                            <h2 class="fw-bold mt-2">
                                12
                            </h2>

                        </div>

                        <div class="icon-box bg-primary">

                            <i class="bi bi-person-badge"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-lg-3 col-md-6">

            <div class="card dashboard-card border-0 shadow-sm">

                <div class="card-body">

                    <div class="d-flex justify-content-between">

                        <div>

                            <small class="text-muted">
                                Patients
                            </small>

                            <h2 class="fw-bold mt-2">
                                258
                            </h2>

                        </div>

                        <div class="icon-box bg-success">

                            <i class="bi bi-people"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-lg-3 col-md-6">

            <div class="card dashboard-card border-0 shadow-sm">

                <div class="card-body">

                    <div class="d-flex justify-content-between">

                        <div>

                            <small class="text-muted">
                                Appointments
                            </small>

                            <h2 class="fw-bold mt-2">
                                42
                            </h2>

                        </div>

                        <div class="icon-box bg-warning">

                            <i class="bi bi-calendar-check"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-lg-3 col-md-6">

            <div class="card dashboard-card border-0 shadow-sm">

                <div class="card-body">

                    <div class="d-flex justify-content-between">

                        <div>

                            <small class="text-muted">
                                Revenue
                            </small>

                            <h2 class="fw-bold mt-2">
                                GHS 12,500
                            </h2>

                        </div>

                        <div class="icon-box bg-danger">

                            <i class="bi bi-cash-stack"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <!-- Appointment Status -->

    <div class="row g-4 mb-4">

        <div class="col-lg-3">

            <div class="card border-0 shadow-sm">

                <div class="card-body text-center">

                    <h4 class="text-primary fw-bold">
                        10
                    </h4>

                    <div>Today's Appointments</div>

                </div>

            </div>

        </div>

        <div class="col-lg-3">

            <div class="card border-0 shadow-sm">

                <div class="card-body text-center">

                    <h4 class="text-warning fw-bold">
                        5
                    </h4>

                    <div>Pending</div>

                </div>

            </div>

        </div>

        <div class="col-lg-3">

            <div class="card border-0 shadow-sm">

                <div class="card-body text-center">

                    <h4 class="text-success fw-bold">
                        18
                    </h4>

                    <div>Completed</div>

                </div>

            </div>

        </div>

        <div class="col-lg-3">

            <div class="card border-0 shadow-sm">

                <div class="card-body text-center">

                    <h4 class="text-danger fw-bold">
                        2
                    </h4>

                    <div>Cancelled</div>

                </div>

            </div>

        </div>

    </div>

    <!-- Tables -->

    <div class="row">

        <!-- Recent Appointments -->

        <div class="col-lg-8 mb-4">

            <div class="card border-0 shadow-sm">

                <div class="card-header bg-white">

                    <h5 class="mb-0">
                        Recent Appointments
                    </h5>

                </div>

                <div class="card-body p-0">

                    <table class="table table-hover mb-0">

                        <thead class="table-light">

                            <tr>

                                <th>Patient</th>

                                <th>Doctor</th>

                                <th>Date</th>

                                <th>Time</th>

                                <th>Status</th>

                            </tr>

                        </thead>

                        <tbody>

                            <tr>

                                <td>John Doe</td>

                                <td>Dr. Mensah</td>

                                <td>Today</td>

                                <td>09:00 AM</td>

                                <td>
                                    <span class="badge bg-warning">
                                        Pending
                                    </span>
                                </td>

                            </tr>

                            <tr>

                                <td>Mary Johnson</td>

                                <td>Dr. Williams</td>

                                <td>Today</td>

                                <td>10:30 AM</td>

                                <td>
                                    <span class="badge bg-success">
                                        Completed
                                    </span>
                                </td>

                            </tr>

                            <tr>

                                <td>Samuel Owusu</td>

                                <td>Dr. Brown</td>

                                <td>Tomorrow</td>

                                <td>08:30 AM</td>

                                <td>
                                    <span class="badge bg-primary">
                                        Confirmed
                                    </span>
                                </td>

                            </tr>

                        </tbody>

                    </table>

                </div>

            </div>

        </div>

        <!-- Quick Actions -->

        <div class="col-lg-4">

            <div class="card border-0 shadow-sm mb-4">

                <div class="card-header bg-white">

                    <h5 class="mb-0">
                        Quick Actions
                    </h5>

                </div>

                <div class="card-body d-grid gap-3">

                    <a href="/doctors" class="btn btn-outline-primary">
                        <i class="bi bi-person-plus me-2"></i>
                        Add Doctor
                    </a>

                    <a href="/patients" class="btn btn-outline-success">
                        <i class="bi bi-person-plus-fill me-2"></i>
                        Register Patient
                    </a>

                    <a href="/appointments" class="btn btn-outline-warning">
                        <i class="bi bi-calendar-plus me-2"></i>
                        Schedule Appointment
                    </a>

                    <a href="/billing" class="btn btn-outline-danger">
                        <i class="bi bi-receipt me-2"></i>
                        Generate Bill
                    </a>

                </div>

            </div>

        </div>

    </div>
</PageShell>